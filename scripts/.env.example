# "staging" or "production"
CROSSMINT_ENV=staging

# Server-side API key from Crossmint console (prefix: sk_staging_ or sk_production_)
# Get from: https://www.crossmint.com/console/projects/apiKeys
CROSSMINT_SERVER_API_KEY=sk_staging_...

# Email linked to the Crossmint smart wallet (used as wallet owner identity)
CROSSMINT_WALLET_EMAIL=test@example.com

# EVM private key — acts as adminSigner on the Crossmint EVM smart wallet (no OTP needed)
# Generate: node -e "const {ethers}=require('ethers'); console.log(ethers.Wallet.createRandom().privateKey)"
EVM_PRIVATE_KEY=0x...

# Stellar ed25519 secret key — acts as adminSigner on the Crossmint Stellar smart wallet
# Generate: node -e "import('@stellar/stellar-base').then(({Keypair})=>{ const kp=Keypair.random(); console.log('secret:',kp.secret(),'\\npublic:',kp.publicKey()) })"
STELLAR_SERVER_KEY=S...

# Base JSON-RPC endpoint (default works for mainnet)
BASE_RPC_URL=https://mainnet.base.org

# Stellar/Soroban RPC URLs (defaults work for mainnet)
SOROBAN_RPC_URL=https://rpc.stellar.org:443
STELLAR_HORIZON_URL=https://horizon.stellar.org

# JWT for Near Intents 1Click API (mainnet only, optional)
# Get from: https://docs.google.com/forms/d/e/1FAIpQLSdrSrqSkKOMb_a8XhwF0f7N5xZ0Y5CYgyzxiAuoC2g4a2N68g/viewform
NEAR_INTENTS_JWT=
