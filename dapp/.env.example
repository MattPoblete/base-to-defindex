# Crossmint client-side API key (prefix: ck_staging_ or ck_production_)
# Get from: https://www.crossmint.com/console/projects/apiKeys
NEXT_PUBLIC_CROSSMINT_API_KEY=ck_staging_...

# Base mainnet JSON-RPC endpoint
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org

# Stellar/Soroban RPC endpoints
NEXT_PUBLIC_SOROBAN_RPC_URL=https://rpc.stellar.org:443
NEXT_PUBLIC_STELLAR_HORIZON_URL=https://horizon.stellar.org
